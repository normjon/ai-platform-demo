{
  "title": "Enterprise AI Platform — Orchestrator Routing & Health",
  "uid": "ai-platform-orchestrator",
  "version": 1,
  "schemaVersion": 36,
  "timezone": "utc",
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "tags": ["ai-platform", "operational", "orchestrator", "routing"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "dev,staging,production",
        "current": { "value": "dev", "text": "dev" },
        "options": [
          { "value": "dev", "text": "dev", "selected": true },
          { "value": "staging", "text": "staging", "selected": false },
          { "value": "production", "text": "production", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "project_id",
        "label": "Project",
        "type": "custom",
        "query": "ai-platform",
        "current": { "value": "ai-platform", "text": "ai-platform" },
        "hide": 2,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Amazon Managed Prometheus — dev", "value": "amp-dev" },
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Orchestrator — Invocation signals",
      "description": "End-to-end orchestrator metrics emitted by the container via put_metric_data. Dimensions: AgentId=orchestrator-dev, Environment.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Orchestrator invocations — last 1h",
      "description": "Count of orchestrator invocations in the last hour. Derived from DispatchCount (the orchestrator emits dispatch metrics at most once per turn). A flat zero while agent runtimes show traffic means invocations are failing before dispatch — check PII scan and the router model call.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(sum_over_time(cloudwatch_bedrock_agentcore_DispatchCount_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[1h]))",
          "legendFormat": "Invocations",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Orchestrator P95 latency (ms) — last 1h",
      "description": "95th percentile orchestrator end-to-end latency over the last hour. Includes inbound PII scan, router model call, sub-agent dispatch, and outbound PII scan. Values above 25 000 ms indicate the pipeline is pressing the user-experience SLO — compare against DispatchLatency per DispatchedAgent to localise.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "max_over_time(cloudwatch_bedrock_agentcore_OrchestratorInvocationLatency_max{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[1h])",
          "legendFormat": "P95 ms",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "orange", "value": 20000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dispatch failure rate (%) — last 1h",
      "description": "Percentage of dispatch attempts that failed (InvokeAgentRuntime ClientError or response decode error). Any sustained value above 1% warrants checking the orchestrator runtime log group for `dispatch_invoke_failed` events.",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "100 * sum(sum_over_time(cloudwatch_bedrock_agentcore_DispatchFailure_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[1h])) / clamp_min(sum(sum_over_time(cloudwatch_bedrock_agentcore_DispatchCount_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[1h])), 1)",
          "legendFormat": "Failure %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Routing failures — last 1h",
      "description": "Sum of RoutingFailureUnknownDomain and RoutingFailureAgentDisabled over the last hour. Non-zero values mean the router chose a domain outside the registry's advertised set or the target agent is disabled — refresh the registry prompt or re-enable the target.",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(sum_over_time(cloudwatch_bedrock_agentcore_RoutingFailureUnknownDomain_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[1h])) + sum(sum_over_time(cloudwatch_bedrock_agentcore_RoutingFailureAgentDisabled_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[1h]))",
          "legendFormat": "Routing failures",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Orchestrator latency over time (avg / max)",
      "description": "End-to-end orchestrator invocation latency over time. Average tracks typical user experience; max shows worst-case. If max diverges significantly from average, a single slow sub-agent is skewing the tail — cross-check DispatchLatency per DispatchedAgent below.",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum_over_time(cloudwatch_bedrock_agentcore_OrchestratorInvocationLatency_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]) / clamp_min(sum_over_time(cloudwatch_bedrock_agentcore_OrchestratorInvocationLatency_count{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]), 1)",
          "legendFormat": "Avg latency (ms)",
          "refId": "A"
        },
        {
          "expr": "max_over_time(cloudwatch_bedrock_agentcore_OrchestratorInvocationLatency_max{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m])",
          "legendFormat": "Max latency (ms)",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "orange", "value": 20000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Dispatch — per sub-agent breakdown",
      "description": "Metrics scoped by DispatchedAgent. Use these panels to spot traffic skew, per-agent latency regressions, and per-agent failure spikes.",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Dispatch volume by sub-agent",
      "description": "Count of dispatch attempts per 5m window, broken down by DispatchedAgent. Reflects the router's actual traffic split. A sudden shift in distribution without a prompt or registry change usually means the router has regressed on domain classification.",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum by (DispatchedAgent) (sum_over_time(cloudwatch_bedrock_agentcore_DispatchCount_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "{{DispatchedAgent}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "bars" }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Dispatch latency by sub-agent (avg / max)",
      "description": "Cross-runtime InvokeAgentRuntime round-trip latency per sub-agent. This is the dispatch cost only — orchestrator-side PII scan and router model time are NOT included. Subtract max DispatchLatency from max OrchestratorInvocationLatency to isolate orchestrator overhead.",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum by (DispatchedAgent) (sum_over_time(cloudwatch_bedrock_agentcore_DispatchLatency_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m])) / clamp_min(sum by (DispatchedAgent) (sum_over_time(cloudwatch_bedrock_agentcore_DispatchLatency_count{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m])), 1)",
          "legendFormat": "{{DispatchedAgent}} — avg",
          "refId": "A"
        },
        {
          "expr": "max by (DispatchedAgent) (max_over_time(cloudwatch_bedrock_agentcore_DispatchLatency_max{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "{{DispatchedAgent}} — max",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Dispatch success vs failure by sub-agent",
      "description": "Success and failure counts per 5m window, per DispatchedAgent. Failures indicate InvokeAgentRuntime ClientError or response decode error — check the orchestrator runtime log group for `dispatch_invoke_failed` events with matching agent_id.",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum by (DispatchedAgent) (sum_over_time(cloudwatch_bedrock_agentcore_DispatchSuccess_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "{{DispatchedAgent}} — success",
          "refId": "A"
        },
        {
          "expr": "sum by (DispatchedAgent) (sum_over_time(cloudwatch_bedrock_agentcore_DispatchFailure_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "{{DispatchedAgent}} — failure",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "bars" }
        }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "PII redaction",
      "description": "PII entity types detected on inbound prompts and outbound responses by Comprehend DetectPiiEntities. A silent zero on live traffic is a warning sign — the Comprehend VPC endpoint or IAM permission is likely the cause.",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "PII detected — inbound vs outbound",
      "description": "Count of PII entity types detected per 5m window. Inbound covers user prompts; outbound covers responses returned by sub-agents. Sustained non-zero outbound is the higher-severity signal — the sub-agent is leaking PII that the orchestrator must redact.",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(sum_over_time(cloudwatch_bedrock_agentcore_PiiDetectedInbound_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "Inbound PII types",
          "refId": "A"
        },
        {
          "expr": "sum(sum_over_time(cloudwatch_bedrock_agentcore_PiiDetectedOutbound_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "Outbound PII types",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Router model (orchestrator's own Strands loop)",
      "description": "Input and output tokens consumed by the orchestrator's router model — the model that decides whether and where to dispatch. Sub-agent tokens are reported under each sub-agent's dashboard, not here.",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Router token consumption over time",
      "description": "Input and output tokens consumed by the orchestrator's router model per 5m window. Sudden upward drift on input tokens usually means the registry prompt or system prompt has grown. Sudden upward drift on output tokens usually means the router is answering inline rather than dispatching — investigate the trace for a missing tool_use block.",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(sum_over_time(cloudwatch_bedrock_agentcore_OrchestratorInputTokens_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "Input tokens",
          "refId": "A"
        },
        {
          "expr": "sum(sum_over_time(cloudwatch_bedrock_agentcore_OrchestratorOutputTokens_sum{environment=\"$environment\", AgentId=\"orchestrator-dev\"}[5m]))",
          "legendFormat": "Output tokens",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    }
  ]
}
