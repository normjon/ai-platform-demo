{
  "title": "Enterprise AI Platform — Agent Operational Health",
  "uid": "ai-platform-agent-operational-health",
  "version": 1,
  "schemaVersion": 36,
  "timezone": "utc",
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "tags": ["ai-platform", "operational", "lambda", "bedrock"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "dev,staging,production",
        "current": { "value": "dev", "text": "dev" },
        "options": [
          { "value": "dev", "text": "dev", "selected": true },
          { "value": "staging", "text": "staging", "selected": false },
          { "value": "production", "text": "production", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "project_id",
        "label": "Project",
        "type": "custom",
        "query": "ai-platform",
        "current": { "value": "ai-platform", "text": "ai-platform" },
        "hide": 2,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Amazon Managed Prometheus — dev", "value": "amp-dev"},
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Prompt vault writer invocations — last 1h",
      "description": "Total number of Prompt Vault writer Lambda invocations in the last hour. Each invocation corresponds to one HR Assistant agent interaction that completed and was written to the vault. A sudden drop indicates agents are not completing interactions successfully.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\", FunctionName=~\".*prompt-vault-writer.*\"}[1h]))",
          "legendFormat": "Invocations",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Lambda error rate — last 1h",
      "description": "Percentage of Lambda invocations that ended with an error in the last hour. Covers the quality scorer and prompt vault writer. Any value above 1% warrants investigation. Check CloudWatch Logs for the specific error event.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "100 * sum(increase(cloudwatch_AWS_Lambda_Errors_sum{environment=\"$environment\"}[1h])) / clamp_min(sum(increase(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\"}[1h])), 1)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "unit": "percent"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bedrock P95 invocation latency (ms)",
      "description": "95th percentile Bedrock model invocation latency in milliseconds over the last hour. This represents the worst-case end-to-end model call time experienced by 95% of invocations. Values above 15 000 ms indicate model latency is likely impacting user-visible response time.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "avg_over_time(cloudwatch_AWS_Bedrock_InvocationLatency_max{environment=\"$environment\"}[1h])",
          "legendFormat": "P95 ms",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "orange", "value": 8000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Lambda throttles — last 1h",
      "description": "Count of Lambda invocations throttled due to concurrency limits in the last hour. Non-zero values mean interactions may have failed or been delayed. Increase the reserved concurrency limit on the prompt vault writer or quality scorer if throttling persists.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AWS_Lambda_Throttles_sum{environment=\"$environment\"}[1h]))",
          "legendFormat": "Throttles",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Lambda invocation rate over time",
      "description": "Rate of Lambda invocations per minute for each AI platform function. The prompt vault writer rate tracks agent invocation volume. The quality scorer fires once per hour on schedule. A drop in prompt vault writer invocations while agent traffic continues indicates the vault writer is failing silently.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\", FunctionName=~\".*prompt-vault-writer.*\"}[5m])",
          "legendFormat": "Prompt vault writer",
          "refId": "A"
        },
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\", FunctionName=~\".*quality-scorer.*\"}[5m])",
          "legendFormat": "Quality scorer",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Bedrock invocation latency over time (P50 / P95)",
      "description": "Bedrock model invocation latency over time. P50 represents median latency for typical interactions; P95 captures tail latency affecting the worst 5% of users. If P95 diverges significantly from P50, a subset of invocations are experiencing severe latency — check for retries or large context windows.",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "avg_over_time(cloudwatch_AWS_Bedrock_InvocationLatency_sum{environment=\"$environment\"}[5m])",
          "legendFormat": "P50 latency (ms)",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(cloudwatch_AWS_Bedrock_InvocationLatency_max{environment=\"$environment\"}[5m])",
          "legendFormat": "P95 latency (ms)",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Lambda error rate over time",
      "description": "Rate of Lambda errors per minute for quality scorer and prompt vault writer. Any sustained non-zero error rate for the quality scorer creates gaps in the quality record — interactions are not scored until the scorer next runs successfully. For the vault writer, errors mean interaction records are not being persisted.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Errors_sum{environment=\"$environment\", FunctionName=~\".*quality-scorer.*\"}[5m])",
          "legendFormat": "Quality scorer errors",
          "refId": "A"
        },
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Errors_sum{environment=\"$environment\", FunctionName=~\".*prompt-vault-writer.*\"}[5m])",
          "legendFormat": "Prompt vault writer errors",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Bedrock client errors over time",
      "description": "Count of Bedrock invocations returning client errors (4xx) over time. Client errors include throttling (429), invalid model ID (400), and permission errors (403). A spike indicates the platform is approaching on-demand throughput limits or has an IAM configuration issue.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "rate(cloudwatch_AWS_Bedrock_InvocationClientErrors_sum{environment=\"$environment\"}[5m])",
          "legendFormat": "Bedrock client errors",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "AIPlatform/AgentCore — Agent-level signals",
      "description": "Metrics emitted via CloudWatch Metric Filters on the AgentCore runtime log group. True agent-level signals derived from structured JSON log events, not Lambda proxy metrics.",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Agent invocations — last 1h",
      "description": "Count of completed HR Assistant agent invocations in the last hour. Derived from agent_invoke log events via CloudWatch Metric Filter. A drop while Prompt Vault writer invocations continue indicates invocations are failing before completion.",
      "gridPos": { "x": 0, "y": 29, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AIPlatform_AgentCore_AgentInvocationCount_sum{environment=\"$environment\"}[1h]))",
          "legendFormat": "Invocations",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Agent invocation errors — last 1h",
      "description": "Count of unhandled HR Assistant agent invocation errors in the last hour. Derived from invocation_error log events. Any non-zero value means the agent returned HTTP 500 — check the AgentCore runtime log group immediately.",
      "gridPos": { "x": 6, "y": 29, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AIPlatform_AgentCore_AgentInvocationErrors_sum{environment=\"$environment\"}[1h]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "KB retrievals — last 1h",
      "description": "Count of Knowledge Base retrieval operations in the last hour. Derived from kb_retrieve log events. A sustained zero while agent invocations are non-zero indicates KB retrieval is being skipped.",
      "gridPos": { "x": 12, "y": 29, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AIPlatform_AgentCore_KBRetrievalCount_sum{environment=\"$environment\"}[1h]))",
          "legendFormat": "KB retrievals",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Glean tool calls — last 1h",
      "description": "Count of Glean Search MCP tool invocations in the last hour. Derived from glean_search log events. Expected to be low when the KB is satisfying queries without tool use.",
      "gridPos": { "x": 18, "y": 29, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AIPlatform_AgentCore_GleanCallCount_sum{environment=\"$environment\"}[1h]))",
          "legendFormat": "Glean calls",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Agent invocation latency over time (ms)",
      "description": "End-to-end HR Assistant agent invocation latency in milliseconds. Derived from the latency_ms field in agent_invoke log events. Includes Bedrock model invocation, KB retrieval, and any tool calls. Values above 15 000 ms indicate the agent is approaching the user experience SLO.",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "avg_over_time(cloudwatch_AIPlatform_AgentCore_AgentInvocationLatency_sum{environment=\"$environment\"}[5m])",
          "legendFormat": "Avg latency (ms)",
          "refId": "A"
        },
        {
          "expr": "max_over_time(cloudwatch_AIPlatform_AgentCore_AgentInvocationLatency_max{environment=\"$environment\"}[5m])",
          "legendFormat": "Max latency (ms)",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "orange", "value": 10000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      }
    }
  ]
}
