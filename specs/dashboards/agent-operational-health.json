{
  "title": "Enterprise AI Platform — Agent Operational Health",
  "uid": "ai-platform-agent-operational-health",
  "version": 1,
  "schemaVersion": 36,
  "timezone": "utc",
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "tags": ["ai-platform", "operational", "lambda", "bedrock"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "dev,staging,production",
        "current": { "value": "dev", "text": "dev" },
        "options": [
          { "value": "dev", "text": "dev", "selected": true },
          { "value": "staging", "text": "staging", "selected": false },
          { "value": "production", "text": "production", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "project_id",
        "label": "Project",
        "type": "custom",
        "query": "ai-platform",
        "current": { "value": "ai-platform", "text": "ai-platform" },
        "hide": 2,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Amazon Managed Prometheus — dev", "value": "amp-dev"},
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Prompt vault writer invocations — last 1h",
      "description": "Total number of Prompt Vault writer Lambda invocations in the last hour. Each invocation corresponds to one HR Assistant agent interaction that completed and was written to the vault. A sudden drop indicates agents are not completing interactions successfully.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\", FunctionName=~\".*prompt-vault-writer.*\"}[1h]))",
          "legendFormat": "Invocations",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Lambda error rate — last 1h",
      "description": "Percentage of Lambda invocations that ended with an error in the last hour. Covers the quality scorer and prompt vault writer. Any value above 1% warrants investigation. Check CloudWatch Logs for the specific error event.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "100 * sum(increase(cloudwatch_AWS_Lambda_Errors_sum{environment=\"$environment\"}[1h])) / clamp_min(sum(increase(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\"}[1h])), 1)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "unit": "percent"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bedrock P95 invocation latency (ms)",
      "description": "95th percentile Bedrock model invocation latency in milliseconds over the last hour. This represents the worst-case end-to-end model call time experienced by 95% of invocations. Values above 15 000 ms indicate model latency is likely impacting user-visible response time.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "avg_over_time(cloudwatch_AWS_Bedrock_InvocationLatency_max{environment=\"$environment\"}[1h])",
          "legendFormat": "P95 ms",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "orange", "value": 8000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Lambda throttles — last 1h",
      "description": "Count of Lambda invocations throttled due to concurrency limits in the last hour. Non-zero values mean interactions may have failed or been delayed. Increase the reserved concurrency limit on the prompt vault writer or quality scorer if throttling persists.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "sum(increase(cloudwatch_AWS_Lambda_Throttles_sum{environment=\"$environment\"}[1h]))",
          "legendFormat": "Throttles",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Lambda invocation rate over time",
      "description": "Rate of Lambda invocations per minute for each AI platform function. The prompt vault writer rate tracks agent invocation volume. The quality scorer fires once per hour on schedule. A drop in prompt vault writer invocations while agent traffic continues indicates the vault writer is failing silently.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\", FunctionName=~\".*prompt-vault-writer.*\"}[5m])",
          "legendFormat": "Prompt vault writer",
          "refId": "A"
        },
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Invocations_sum{environment=\"$environment\", FunctionName=~\".*quality-scorer.*\"}[5m])",
          "legendFormat": "Quality scorer",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Bedrock invocation latency over time (P50 / P95)",
      "description": "Bedrock model invocation latency over time. P50 represents median latency for typical interactions; P95 captures tail latency affecting the worst 5% of users. If P95 diverges significantly from P50, a subset of invocations are experiencing severe latency — check for retries or large context windows.",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "avg_over_time(cloudwatch_AWS_Bedrock_InvocationLatency_sum{environment=\"$environment\"}[5m])",
          "legendFormat": "P50 latency (ms)",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(cloudwatch_AWS_Bedrock_InvocationLatency_max{environment=\"$environment\"}[5m])",
          "legendFormat": "P95 latency (ms)",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Lambda error rate over time",
      "description": "Rate of Lambda errors per minute for quality scorer and prompt vault writer. Any sustained non-zero error rate for the quality scorer creates gaps in the quality record — interactions are not scored until the scorer next runs successfully. For the vault writer, errors mean interaction records are not being persisted.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Errors_sum{environment=\"$environment\", FunctionName=~\".*quality-scorer.*\"}[5m])",
          "legendFormat": "Quality scorer errors",
          "refId": "A"
        },
        {
          "expr": "rate(cloudwatch_AWS_Lambda_Errors_sum{environment=\"$environment\", FunctionName=~\".*prompt-vault-writer.*\"}[5m])",
          "legendFormat": "Prompt vault writer errors",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Bedrock client errors over time",
      "description": "Count of Bedrock invocations returning client errors (4xx) over time. Client errors include throttling (429), invalid model ID (400), and permission errors (403). A spike indicates the platform is approaching on-demand throughput limits or has an IAM configuration issue.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "amp-dev" },
      "targets": [
        {
          "expr": "rate(cloudwatch_AWS_Bedrock_InvocationClientErrors_sum{environment=\"$environment\"}[5m])",
          "legendFormat": "Bedrock client errors",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}
