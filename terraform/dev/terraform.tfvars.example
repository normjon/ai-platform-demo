# Copy this file to terraform.tfvars and fill in values.
# terraform.tfvars is git-ignored — never commit it.

aws_region   = "us-east-2"
account_id   = "096305373014"
environment  = "dev"
project_name = "ai-platform"

vpc_cidr             = "10.0.0.0/16"
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

# Approved model ARNs — do not change without updating the agent manifest.
model_arn_primary    = "anthropic.claude-sonnet-4-6"
model_arn_evaluation = "anthropic.claude-haiku-4-5-20251001"

# ECR image URI for the HR Assistant agent. Tag must be a git SHA - never 'latest' (ADR-009).
# The ECR repository is created by terraform apply. Get the URL from:
#   terraform output ecr_repository_url
# Push a valid arm64 image to the repo before running terraform apply a second time
# (the AgentCore runtime validates the URI and image existence at create time).
agent_image_uri = "096305373014.dkr.ecr.us-east-2.amazonaws.com/ai-platform-dev-hr-assistant:<git-sha>"

# Glean MCP tool endpoint registered in the AgentCore Gateway.
glean_mcp_endpoint = "https://placeholder.glean.com/mcp"
