# Copy this file to terraform.tfvars and fill in values.
# terraform.tfvars is git-ignored — never commit it.

aws_region = "us-east-1"
account_id = "<your-aws-account-id>"
environment = "dev"
project_name = "ai-platform"

vpc_cidr             = "10.0.0.0/16"
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

# Approved model ARNs — do not change without updating the agent manifest.
model_arn_primary    = "anthropic.claude-sonnet-4-6"
model_arn_evaluation = "anthropic.claude-haiku-4-5-20251001"
model_arn_embeddings = "amazon.titan-embed-text-v2:0"

# ECR image URI for the HR Assistant agent. Tag must be a git SHA — never 'latest'.
agent_image_uri = "<account-id>.dkr.ecr.<region>.amazonaws.com/ai-platform-hr-assistant:<git-sha>"

# Glean MCP tool endpoint registered in the AgentCore Gateway.
glean_mcp_endpoint = "https://<your-glean-tenant>.glean.com/mcp"
